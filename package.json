{
  "name": "rs3-discord-bot",
  "version": "0.1.0",
  "private": true,
  "description": "A standalone RS3-inspired Discord RPG.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "register-commands": "node --env-file-if-exists=.env --import tsx src/scripts/register-commands.ts",
    "register-skill-emojis": "node --env-file-if-exists=.env --import tsx src/scripts/register-skill-emojis.ts",
    "migrate": "node --env-file-if-exists=.env --import tsx src/scripts/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "discord.js": "^14.22.1",
    "opentype.js": "^2.0.0",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "sharp": "^0.35.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.1",
    "@types/opentype.js": "^1.3.10",
    "@types/pg": "^8.15.5",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  }
}
