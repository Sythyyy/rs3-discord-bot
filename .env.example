# Required Discord application credentials. Never commit the real values.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# PostgreSQL connection string for the bot's dedicated database user.
DATABASE_URL=postgres://rs3_bot:change-me@localhost:5432/rs3_bot

# Use a development guild to make slash-command updates available immediately.
# Omit this value to register global commands (which can take up to an hour).
DISCORD_GUILD_ID=

# debug | info | warn | error
LOG_LEVEL=info
