DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-id
DATABASE_URL=postgresql://rs3_bot:change-me@localhost:5432/rs3_bot

# Optional: register commands instantly in one development server.
DISCORD_GUILD_ID=
LOG_LEVEL=info
NODE_ENV=development
GAME_SPEED_MULTIPLIER=0.23

# Optional: stable secret for persistent Discord buttons (minimum 16 characters).
# If omitted, DISCORD_TOKEN is used. Preserve this value once configured.
BUTTON_SIGNING_SECRET=
